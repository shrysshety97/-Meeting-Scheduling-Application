    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.2",
    "@types/nodemailer": "^6.4.15",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
